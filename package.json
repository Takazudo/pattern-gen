{
  "name": "@takazudo/zudo-pattern-gen",
  "version": "0.1.0",
  "description": "Generate deterministic visual patterns from text seeds — 30 algorithms from geometric tiles to noise-based textures",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "pattern-gen": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:deps": "pnpm --filter @takazudo/pattern-gen-core run build && pnpm --filter @takazudo/pattern-gen-image-processor run build && pnpm --filter @takazudo/pattern-gen-generators run build",
    "build": "pnpm run build:deps && tsup",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "prepublishOnly": "pnpm run build && vitest run",
    "// ── Viewer ──────────────────────────────────────": "",
    "previewer:dev": "lsof -ti :14362 | xargs kill 2>/dev/null; true",
    "viewer:dev": "pnpm --filter pattern-gen-viewer dev",
    "previewer:dev:net": "lsof -ti :14362 | xargs kill 2>/dev/null; true",
    "viewer:dev:net": "pnpm --filter pattern-gen-viewer dev -- --host 0.0.0.0",
    "viewer:build": "pnpm --filter pattern-gen-viewer build",
    "// ── Doc site ────────────────────────────────────": "",
    "predoc:dev": "lsof -ti :4321 | xargs kill 2>/dev/null; true",
    "doc:dev": "cd doc && pnpm run dev",
    "predoc:dev:net": "lsof -ti :4321 | xargs kill 2>/dev/null; true",
    "doc:dev:net": "cd doc && pnpm run dev -- --host 0.0.0.0",
    "doc:build": "cd doc && pnpm run build",
    "doc:check": "cd doc && pnpm run check",
    "// ── Validation ──────────────────────────────────": "",
    "b4push": "./scripts/run-b4push.sh",
    "// ── Typecheck ───────────────────────────────────": "",
    "typecheck": "pnpm --filter @takazudo/pattern-gen-core run typecheck && pnpm --filter @takazudo/pattern-gen-image-processor run typecheck && pnpm --filter @takazudo/pattern-gen-generators run typecheck && tsc --noEmit"
  },
  "keywords": [
    "pattern",
    "generative",
    "geometric",
    "texture",
    "canvas",
    "cli",
    "deterministic"
  ],
  "author": "Takazudo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Takazudo/pattern-gen.git"
  },
  "bugs": {
    "url": "https://github.com/Takazudo/pattern-gen/issues"
  },
  "packageManager": "pnpm@10.32.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@takazudo/pattern-gen-core": "workspace:*",
    "@takazudo/pattern-gen-generators": "workspace:*",
    "canvas": "^3.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260403.1",
    "@types/node": "^22.0.0",
    "hono": "^4.12.10",
    "jose": "^6.2.2",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  },
  "pnpm": {
    "overrides": {
      "chokidar": "^5.0.0",
      "undici-types": "^7.22.0"
    },
    "onlyBuiltDependencies": [
      "canvas",
      "esbuild",
      "workerd"
    ]
  }
}
