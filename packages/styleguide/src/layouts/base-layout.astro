---
import '../styles/global.css';
// Import viewer App.css for component styles (btn, modal, auth, gallery, collapsible, etc.)
import '@viewer/App.css';
// Import viewer component-specific CSS files
import '@viewer/components/step-indicator.css';
import '@viewer/components/composer.css';
import '@viewer/components/overlay-shared.css';
import '@viewer/components/hsla-color-picker.css';
import '@viewer/components/selection-overlay.css';
import '@viewer/components/image-overlay-transform.css';
import '@viewer/components/image-trace-preview.css';

interface Props {
  title: string;
  currentPath?: string;
}

const { title, currentPath } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} - Pattern Gen Styleguide</title>
  </head>
  <body>
    <div class="sg-layout">
      <header class="sg-header">
        <span class="sg-header-title">Pattern Gen Styleguide</span>
        <nav class="sg-header-nav">
          <a href="/" aria-current={currentPath === '/' ? 'page' : undefined}>
            Stories
          </a>
          <a
            href="/docs/css-architecture"
            aria-current={currentPath?.startsWith('/docs') ? 'page' : undefined}
          >
            CSS Architecture
          </a>
        </nav>
      </header>
      <slot />
    </div>
  </body>
</html>
