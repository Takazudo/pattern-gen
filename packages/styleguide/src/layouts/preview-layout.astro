---
import '../styles/global.css';
import ColorSchemeProvider from '../components/color-scheme-provider.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Preview</title>
    <ColorSchemeProvider />
    <style>
      html,
      body {
        margin: 0;
        padding: 0;
      }
      /* Constrain to article column width — wider content doesn't reflect real render context */
      .preview-wrapper {
        max-width: 800px;
      }
      /* Hide Astro dev toolbar inside preview iframes */
      astro-dev-toolbar {
        display: none !important;
      }
    </style>
  </head>
  <body class="bg-bg text-fg font-sans text-body">
    <div class="preview-wrapper">
      <slot />
    </div>
  </body>
</html>
