---
import DocLayout from '../layouts/doc-layout.astro';
import { getStorySidebarNodes } from '../utils/story-sidebar';
import { getCategoryTree } from '../data/stories';
import type { NavNode } from '../utils/story-sidebar';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const storyTree = getStorySidebarNodes(base);
const categories = getCategoryTree();
const totalStories = categories.reduce((sum, cat) => sum + cat.stories.length, 0);
---

<DocLayout title="Components" hideToc={true}>
  <h1 class="font-bold text-heading pb-vsp-3xs">Components</h1>
  <p class="text-muted text-small pb-vsp-lg">
    {totalStories} components across {categories.length} categories
  </p>

  <nav aria-label="Component directory" class="mb-vsp-xl">
    <ul class="list-none m-0 p-0">
      {
        storyTree.map((category: NavNode) => (
          <li class="m-0 p-0 pb-vsp-sm">
            <span class="inline-block py-vsp-3xs text-fg font-semibold text-sm">
              {category.label}
            </span>
            {category.children.length > 0 && (
              <ul class="list-none m-0 p-0 pl-hsp-lg ml-hsp-xs">
                {category.children.map((child: NavNode) => (
                  <li class="m-0 p-0">
                    {child.href ? (
                      <a
                        href={child.href}
                        class="inline-block py-vsp-3xs text-accent hover:underline text-sm"
                      >
                        {child.label}
                      </a>
                    ) : (
                      <span class="inline-block py-vsp-3xs text-fg">{child.label}</span>
                    )}
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))
      }
    </ul>
  </nav>
</DocLayout>
