---
import BaseLayout from '../../layouts/base-layout.astro';
import { Sidebar } from '../../components/sidebar';
import { getStoriesByCategory } from '../../data/stories';
import CssArchitectureContent from '../../content/docs/css-architecture.mdx';

const categories = getStoriesByCategory();
---

<BaseLayout title="CSS Architecture" currentPath="/docs/css-architecture">
  <Sidebar client:load categories={categories} />
  <main class="sg-main">
    <div class="sg-prose">
      <CssArchitectureContent />
    </div>
  </main>
</BaseLayout>
